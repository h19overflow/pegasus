# Bright Data Credentials
# Dashboard: https://brightdata.com/cp

# Account
BRIGHTDATA_CUSTOMER_ID=your_brightdata_customer_id_here

# Scraping Browser Zone
BRIGHTDATA_BROWSER_ZONE=scraping_browser1
BRIGHTDATA_BROWSER_PASSWORD=your_browser_zone_password_here

# Connection strings (derived)
BRIGHTDATA_BROWSER_WSS=wss://brd-customer-YOUR_CUSTOMER_ID-zone-scraping_browser1:YOUR_PASSWORD@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_HTTPS=https://brd-customer-YOUR_CUSTOMER_ID-zone-scraping_browser1:YOUR_PASSWORD@brd.superproxy.io:9515

# Web Unlocker Zone (pending — share zone name + password)
# BRIGHTDATA_UNLOCKER_ZONE=
# BRIGHTDATA_UNLOCKER_PASSWORD=

# API Key / Bearer Token (for Web Scraper API, SERP API, Crawl API)
BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# SERP API Zone
BRIGHTDATA_SERP_ZONE=serp_api1

# MCP Server
BRIGHTDATA_MCP_URL=https://mcp.brightdata.com/mcp?token=your_brightdata_api_key_here

# Google Gemini (AI Chatbot)
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
