# Bright Data Credentials
# Dashboard: https://brightdata.com/cp

# Account
BRIGHTDATA_CUSTOMER_ID=hl_XXXXXXXX

# Scraping Browser Zone
BRIGHTDATA_BROWSER_ZONE=scraping_browser1
BRIGHTDATA_BROWSER_PASSWORD=your_password_here

# Connection strings (derived)
BRIGHTDATA_BROWSER_WSS=wss://brd-customer-${BRIGHTDATA_CUSTOMER_ID}-zone-${BRIGHTDATA_BROWSER_ZONE}:${BRIGHTDATA_BROWSER_PASSWORD}@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_HTTPS=https://brd-customer-${BRIGHTDATA_CUSTOMER_ID}-zone-${BRIGHTDATA_BROWSER_ZONE}:${BRIGHTDATA_BROWSER_PASSWORD}@brd.superproxy.io:9515

# Web Unlocker Zone
BRIGHTDATA_UNLOCKER_ZONE=your_zone_name
BRIGHTDATA_UNLOCKER_PASSWORD=your_password_here

# API Key / Bearer Token (for Web Scraper API, SERP API, Crawl API)
BRIGHTDATA_API_KEY=your_api_key_here
